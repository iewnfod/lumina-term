{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "lumina-term",
    "version": "0.1.0",
    "identifier": "com.iewnfod.lumina-term",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "lumina-term",
                "width": 600,
                "height": 400,
                "minWidth": 600,
                "minHeight": 400,
                "transparent": true,
                "decorations": false,
                "visible": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
