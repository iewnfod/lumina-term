{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Lumina Terminal",
    "version": "0.1.0",
    "identifier": "com.iewnfod.lumina-terminal",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Lumina Terminal",
                "width": 600,
                "height": 400,
                "minWidth": 600,
                "minHeight": 400,
                "transparent": true,
                "decorations": true,
                "titleBarStyle": "Overlay",
                "visible": false,
                "hiddenTitle": true,
                "trafficLightPosition": {
                    "x": 18,
                    "y": 18
                }
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
